# Loopy OSS — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://loopy:password@localhost:5432/loopy
POSTGRES_PASSWORD=change_me_in_production

# ── Auth ───────────────────────────────────────────────────────────────────────

# Self-hosted: symmetric secret for signing and verifying JWTs.
# Generate a secure value with: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# Supabase hosted (alternative to JWT_SECRET):
# If set, JWTs are verified against Supabase's JWKS endpoint.
# Leave blank for self-hosted deployments.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── API ────────────────────────────────────────────────────────────────────────
PORT=3001

# Allowed CORS origin. Use '*' for local dev, set your exact frontend URL in production.
# Example: https://app.loopythinking.ai
CORS_ORIGIN=*

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ── IPL weight overrides (optional) ───────────────────────────────────────────
# Override the default heuristic weights for IPL calculation.
# Values must be integers between 0 and 480 (minutes per signal).
# If omitted, the OSS defaults are used (perception=3, interpretation=8,
# decision=15, action=10, reflection=6).
# Changing these makes IPL values non-comparable with other Loopy instances.
# IPL_WEIGHT_PERCEPTION=3
# IPL_WEIGHT_INTERPRETATION=8
# IPL_WEIGHT_DECISION=15
# IPL_WEIGHT_ACTION=10
# IPL_WEIGHT_REFLECTION=6
