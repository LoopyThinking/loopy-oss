# Loopy OSS — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://loopy:password@localhost:5432/loopy
POSTGRES_PASSWORD=change_me_in_production

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production

# ── Alternativa: Supabase (self-hosted o cloud) ────────────────────────────────
# Si usas Supabase en lugar de PostgreSQL directo, descomenta estas variables:
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...

# ── API ────────────────────────────────────────────────────────────────────────
PORT=3001

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
