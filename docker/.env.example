# ── Email provider (optional — for email invites) ───────────────────────────────
# Uncomment and configure ONE of the following:

# Option A: SMTP
# LOOPY_EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password
# SMTP_FROM=noreply@example.com

